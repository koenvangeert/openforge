{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "src/electron",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/electron/**/*.ts", "src/electron/**/*.cts"],
  "exclude": ["src/electron/**/*.test.ts"]
}
